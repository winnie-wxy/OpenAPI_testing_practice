{
  "info": {
    "_postman_id": "cg-restful-booker-collection",
    "name": "Restful Booker API",
    "description": "API test collection mirroring the pytest test suite. Covers smoke, regression, and contract validation flows.\n\nSetup: Run 'Auth - Create Token' first to populate the {{token}} variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://restful-booker.herokuapp.com"
    }
  ],
  "item": [
    {
      "name": "Smoke",
      "description": "Quick health and basic CRUD checks — mirrors pytest -m smoke",
      "item": [
        {
          "name": "Health Check - Ping",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/ping",
              "host": ["{{base_url}}"],
              "path": ["ping"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Health check returns 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Auth - Create Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth",
              "host": ["{{base_url}}"],
              "path": ["auth"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Auth returns 200 with token', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('token');",
                  "    pm.environment.set('token', jsonData.token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Auth - Invalid Credentials",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"wrong\",\n  \"password\": \"wrong\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth",
              "host": ["{{base_url}}"],
              "path": ["auth"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Invalid credentials return reason', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.reason).to.eql('Bad credentials');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Winnie\",\n  \"lastname\": \"Wei\",\n  \"totalprice\": 250,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2026-06-01\",\n    \"checkout\": \"2026-06-07\"\n  },\n  \"additionalneeds\": \"Breakfast\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/booking",
              "host": ["{{base_url}}"],
              "path": ["booking"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create booking returns 200 with booking ID', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('bookingid');",
                  "    pm.expect(jsonData.bookingid).to.be.a('number');",
                  "    pm.environment.set('booking_id', jsonData.bookingid);",
                  "});",
                  "",
                  "pm.test('Booking data matches payload', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.booking.firstname).to.eql('Winnie');",
                  "    pm.expect(jsonData.booking.lastname).to.eql('Wei');",
                  "    pm.expect(jsonData.booking.totalprice).to.eql(250);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Booking",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/booking/{{booking_id}}",
              "host": ["{{base_url}}"],
              "path": ["booking", "{{booking_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Get booking returns 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Booking has expected fields', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('firstname');",
                  "    pm.expect(jsonData).to.have.property('lastname');",
                  "    pm.expect(jsonData).to.have.property('totalprice');",
                  "    pm.expect(jsonData).to.have.property('depositpaid');",
                  "    pm.expect(jsonData).to.have.property('bookingdates');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Regression",
      "description": "Full CRUD lifecycle and negative tests — mirrors pytest -m regression",
      "item": [
        {
          "name": "Update Booking (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Cookie", "value": "token={{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Updated\",\n  \"lastname\": \"Booking\",\n  \"totalprice\": 500,\n  \"depositpaid\": false,\n  \"bookingdates\": {\n    \"checkin\": \"2026-07-01\",\n    \"checkout\": \"2026-07-10\"\n  },\n  \"additionalneeds\": \"Lunch\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/booking/{{booking_id}}",
              "host": ["{{base_url}}"],
              "path": ["booking", "{{booking_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Update returns 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Updated fields match', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.firstname).to.eql('Updated');",
                  "    pm.expect(jsonData.lastname).to.eql('Booking');",
                  "    pm.expect(jsonData.totalprice).to.eql(500);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Partial Update (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Cookie", "value": "token={{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Patched\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/booking/{{booking_id}}",
              "host": ["{{base_url}}"],
              "path": ["booking", "{{booking_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Patch returns 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Only patched field changed', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.firstname).to.eql('Patched');",
                  "    pm.expect(jsonData.lastname).to.eql('Booking');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Booking",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Cookie", "value": "token={{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/booking/{{booking_id}}",
              "host": ["{{base_url}}"],
              "path": ["booking", "{{booking_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Delete returns 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify Deleted - GET returns 404",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/booking/{{booking_id}}",
              "host": ["{{base_url}}"],
              "path": ["booking", "{{booking_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Deleted booking returns 404', function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Without Auth - 403",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Unauthorized\",\n  \"lastname\": \"Access\",\n  \"totalprice\": 100,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2026-06-01\",\n    \"checkout\": \"2026-06-07\"\n  },\n  \"additionalneeds\": \"None\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/booking/1",
              "host": ["{{base_url}}"],
              "path": ["booking", "1"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Update without auth returns 403', function () {",
                  "    pm.response.to.have.status(403);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Non-Existent Booking - 404",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/booking/9999999",
              "host": ["{{base_url}}"],
              "path": ["booking", "9999999"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Non-existent booking returns 404', function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Contract",
      "description": "Response schema validation — mirrors pytest -m contract",
      "item": [
        {
          "name": "Validate Create Booking Schema",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Schema\",\n  \"lastname\": \"Test\",\n  \"totalprice\": 100,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2026-06-01\",\n    \"checkout\": \"2026-06-07\"\n  },\n  \"additionalneeds\": \"None\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/booking",
              "host": ["{{base_url}}"],
              "path": ["booking"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const schema = {",
                  "    type: 'object',",
                  "    required: ['bookingid', 'booking'],",
                  "    properties: {",
                  "        bookingid: { type: 'number' },",
                  "        booking: {",
                  "            type: 'object',",
                  "            required: ['firstname', 'lastname', 'totalprice', 'depositpaid', 'bookingdates'],",
                  "            properties: {",
                  "                firstname: { type: 'string' },",
                  "                lastname: { type: 'string' },",
                  "                totalprice: { type: 'number' },",
                  "                depositpaid: { type: 'boolean' },",
                  "                bookingdates: {",
                  "                    type: 'object',",
                  "                    required: ['checkin', 'checkout'],",
                  "                    properties: {",
                  "                        checkin: { type: 'string' },",
                  "                        checkout: { type: 'string' }",
                  "                    }",
                  "                }",
                  "            }",
                  "        }",
                  "    }",
                  "};",
                  "",
                  "pm.test('Response matches booking creation schema', function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.response.to.have.jsonSchema(schema);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
